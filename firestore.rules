rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/app_users/$(request.auth.uid)).data;
    }

    function userLoginKey() {
      return userProfile().loginKey != null ? userProfile().loginKey : userProfile().mobile;
    }

    function isAdmin() {
      return authed() && userProfile().isAdmin == true;
    }

    match /app_users/{uid} {
      allow read: if authed() && (request.auth.uid == uid || isAdmin());
      allow create: if authed() && (
        (isAdmin()
          && request.resource.data.keys().hasAll(['loginKey', 'created_at'])
          && request.resource.data.loginKey is string)
        || (
          request.auth.uid == uid
          && request.resource.data.keys().hasAll(['loginKey', 'username', 'created_at'])
          && request.resource.data.loginKey is string
          && request.resource.data.username is string
          && request.resource.data.isAdmin == false
        )
      );
      allow update: if authed() && (request.auth.uid == uid || isAdmin());
      allow delete: if authed() && isAdmin();
    }

    match /products/{id} {
      allow read: if authed() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.userMobile == userLoginKey()
      );
      allow create: if authed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userMobile == userLoginKey();
      allow update: if authed() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.userMobile == userLoginKey() && !('ownerUid' in resource.data))
      );
      allow delete: if authed() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.userMobile == userLoginKey() && !('ownerUid' in resource.data))
      );
    }

    match /warranty_documents/{id} {
      allow read: if authed() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.userMobile == userLoginKey()
      );
      allow create: if authed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userMobile == userLoginKey();
      allow update, delete: if authed() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.userMobile == userLoginKey() && !('ownerUid' in resource.data))
      );
    }
  }
}
