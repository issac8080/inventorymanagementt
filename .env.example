# Copy to `.env` or `.env.local` (recommended: `.env.local` is gitignored via `*.local`).

# --- Firebase (Firestore + Auth + Storage) — optional cloud backend ---
# Firebase Console → Project settings → Your apps → Web app (copy config into these vars)
# Authentication → Get started → Sign-in method → Email/Password → Enable (required; without it login returns auth/configuration-not-found)
# Deploy rules: `firebase deploy --only firestore:rules,storage` (or paste firestore.rules + storage.rules in Console)
VITE_DISABLE_FIREBASE=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Supabase (Postgres + Auth + Storage) — optional web-based cloud alternative ---
# Create a project at https://supabase.com → Settings → API (Project URL + keys)
# Run SQL in `supabase-schema.sql` in the SQL Editor; create Storage bucket `warranties` (private).
# If both Firebase and Supabase are set, Firebase is used unless you set VITE_CLOUD_BACKEND=supabase
#
# Use either VITE_* (recommended for Vite) or NEXT_PUBLIC_* (same names as many Next.js templates):
VITE_DISABLE_SUPABASE=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
VITE_CLOUD_BACKEND=
VITE_BUILTIN_USER_USERNAME=
VITE_BUILTIN_USER_PASSWORD=

# --- Admin / operator (optional; leave empty to disable /admin login) ---
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=
